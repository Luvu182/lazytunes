{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "LazyTunes default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-watch",
    "fs:allow-stat",
    "dialog:default",
    "dialog:allow-open",
    "store:default",
    "global-shortcut:default",
    "global-shortcut:allow-register"
  ]
}
